# Get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot on Telegram
ALLOWED_IDS=123456789,987654321

# Path to your OAuth2 client secret JSON (downloaded from Google Cloud Console)
GDRIVE_CLIENT_SECRET_FILE=client_secret.json

# Path where the OAuth2 token will be saved after running auth.py (auto-generated)
GDRIVE_TOKEN_FILE=token.json

# Optional: Google Drive folder ID to upload files into
# Leave empty to upload to root of your Google Drive
GDRIVE_FOLDER_ID=

# For files larger than 20MB — get these from https://my.telegram.org
# Apps → Create application → copy api_id and api_hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local Bot API server URL (auto-set by deploy.sh, do not change)
LOCAL_API_URL=http://localhost:8081/bot
